# Host-specific compose variables — copy to .env (gitignored) and edit.
#   cp .env.example .env

# Host UDP port published for GDM discovery. Plex clients only discover on
# 32414; change this only when something else (a still-running Plex Media
# Server) owns 32414 on this host. plurx then works fine by direct address
# (http://host:32600) and discovery lights up once you flip this back.
PLURX_GDM_PORT=32414
